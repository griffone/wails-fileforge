{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --host 0.0.0.0",
    "build": "ng build --configuration production",
    "build:dev": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
