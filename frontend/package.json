    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@tailwindcss/postcss": "^4.1.11",
    "@tauri-apps/api": "^2.6.0",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "lucide-angular": "^0.577.0",
    "pdfjs-dist": "^4.10.38",
    "jszip": "3.10.1",
    "pdf-lib": "1.17.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
